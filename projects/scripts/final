import bpy
import math
import os
from mathutils import Vector


# Blender LTS 3.6 full Solar System cinematic
# Sequence:
# 1) Opening deep-space approach
# 2) Focus each body (Sun -> Pluto) with fading labels
# 3) Final wide shot where Pluto completes one full revolution


# -----------------------------
# CONFIG
# -----------------------------
FPS = 24
OPENING_START = 1
OPENING_END = 240
FOCUS_START = OPENING_END + 1
FOCUS_DURATION = 170
FADE_FRAMES = 20

# World scale (artistic, not physical scale)
DIST_SCALE = 5.0
SIZE_SCALE = 1.35
SUN_RADIUS = 7.5

# Orbit timing:
# During focus phase, all planets move slowly.
# During final wide shot, speed ramps so Pluto reaches exactly 1 revolution total.
SLOW_PLUTO_DEG = 22.0
SPEED_COMPRESSION = 0.35


# -----------------------------
# TEXTURES
# -----------------------------
DEFAULT_TEXTURE_DIR = r"C:\COLLEGE\THIRD TERM\MAA\Planets\textures\\"


def candidate_texture_dirs():
    dirs = []

    if os.path.isdir(DEFAULT_TEXTURE_DIR):
        dirs.append(DEFAULT_TEXTURE_DIR)

    script_dir = ""
    if "__file__" in globals():
        script_dir = os.path.dirname(os.path.abspath(__file__))
        local_tex = os.path.join(script_dir, "textures")
        if os.path.isdir(local_tex):
            dirs.append(local_tex)

    if bpy.data.filepath:
        blend_dir = os.path.dirname(bpy.data.filepath)
        blend_tex = os.path.join(blend_dir, "textures")
        if os.path.isdir(blend_tex):
            dirs.append(blend_tex)

    return dirs


def build_texture_index():
    index = {}
    valid_ext = {".jpg", ".jpeg", ".png", ".tif", ".tiff", ".exr", ".hdr"}

    for base in candidate_texture_dirs():
        for root, _, files in os.walk(base):
            for f in files:
                ext = os.path.splitext(f)[1].lower()
                if ext not in valid_ext:
                    continue
                key = os.path.splitext(f)[0].lower()
                full = os.path.join(root, f)
                if key not in index:
                    index[key] = full
    return index


TEXTURE_INDEX = build_texture_index()


def load_texture(*names):
    for name in names:
        key = name.lower()
        if key in TEXTURE_INDEX:
            try:
                return bpy.data.images.load(TEXTURE_INDEX[key], check_existing=True)
            except RuntimeError:
                pass
    return None


# -----------------------------
# HELPERS
# -----------------------------
def clear_scene():
    bpy.ops.object.select_all(action="SELECT")
    bpy.ops.object.delete(use_global=False)


def set_linear_keys(obj):
    if not obj.animation_data or not obj.animation_data.action:
        return
    for fc in obj.animation_data.action.fcurves:
        for kp in fc.keyframe_points:
            kp.interpolation = "LINEAR"


def make_planet_material(name, texture_names, rough=0.7, emission_strength=0.0):
    mat = bpy.data.materials.new(name=f"Mat_{name}")
    mat.use_nodes = True
    nodes = mat.node_tree.nodes
    links = mat.node_tree.links
    nodes.clear()

    out = nodes.new("ShaderNodeOutputMaterial")
    bsdf = nodes.new("ShaderNodeBsdfPrincipled")
    tex = nodes.new("ShaderNodeTexImage")
    img = load_texture(*texture_names)

    if img:
        tex.image = img
        try:
            tex.image.colorspace_settings.name = "sRGB"
        except Exception:
            pass
        links.new(tex.outputs["Color"], bsdf.inputs["Base Color"])
    else:
        bsdf.inputs["Base Color"].default_value = (0.6, 0.6, 0.6, 1.0)

    bsdf.inputs["Roughness"].default_value = rough
    bsdf.inputs["Specular"].default_value = 0.2

    if emission_strength > 0:
        try:
            if img:
                links.new(tex.outputs["Color"], bsdf.inputs["Emission"])
            else:
                bsdf.inputs["Emission"].default_value = (0.9, 0.6, 0.2, 1.0)
            bsdf.inputs["Emission Strength"].default_value = emission_strength
        except Exception:
            pass

    links.new(bsdf.outputs["BSDF"], out.inputs["Surface"])
    return mat


def create_label_for_camera(title, subtitle, camera, start_frame, end_frame):
    bpy.ops.object.text_add(location=(0, 0, 0))
    txt = bpy.context.object
    txt.name = f"Label_{title}"

    # ── NAME ONLY — no subtitle/description ──────────────────────────────────
    txt.data.body = title
    txt.data.align_x = "LEFT"
    txt.data.size = 0.13        # Small: won't crowd the planet in frame
    txt.data.extrude = 0.004

    # Parent to the per-planet camera so it follows it
    txt.parent = camera

    # Position in camera-local space at z = -4.6 (in front of lens).
    # For a 60mm lens on a 36mm sensor the horizontal FOV ≈ 32°.
    # At depth 4.6 the half-width is ~1.32 units → x=-1.05 is safely left of centre.
    # y=-0.72 sits near the bottom quarter of the frame.
    txt.location = (-1.05, -0.72, -4.6)
    txt.rotation_euler = (0.0, 0.0, 0.0)

    mat = bpy.data.materials.new(name=f"Mat_Label_{title}")
    mat.use_nodes = True
    mat.blend_method = "BLEND"
    mat.shadow_method = "NONE"
    txt.data.materials.append(mat)

    nodes = mat.node_tree.nodes
    links = mat.node_tree.links
    nodes.clear()

    out      = nodes.new("ShaderNodeOutputMaterial")
    transparent = nodes.new("ShaderNodeBsdfTransparent")
    emission = nodes.new("ShaderNodeEmission")
    mix      = nodes.new("ShaderNodeMixShader")

    # Pure white, low strength — readable but NOT glowing/blooming
    emission.inputs["Color"].default_value    = (1.0, 1.0, 1.0, 1.0)
    emission.inputs["Strength"].default_value = 1.0   # was 4.0

    links.new(transparent.outputs["BSDF"],   mix.inputs[1])
    links.new(emission.outputs["Emission"],  mix.inputs[2])
    links.new(mix.outputs["Shader"],         out.inputs["Surface"])

    # Fade in / hold / fade out
    in_end     = min(start_frame + FADE_FRAMES, end_frame)
    out_start  = max(start_frame, end_frame - FADE_FRAMES)

    mix.inputs["Fac"].default_value = 0.0
    mix.inputs["Fac"].keyframe_insert(data_path="default_value", frame=start_frame)
    mix.inputs["Fac"].default_value = 1.0
    mix.inputs["Fac"].keyframe_insert(data_path="default_value", frame=in_end)
    mix.inputs["Fac"].default_value = 1.0
    mix.inputs["Fac"].keyframe_insert(data_path="default_value", frame=out_start)
    mix.inputs["Fac"].default_value = 0.0
    mix.inputs["Fac"].keyframe_insert(data_path="default_value", frame=end_frame)


def add_focus_lights(anchor, target, radius, name):
    key_energy = max(120.0, radius * 180.0)
    fill_energy = max(18.0, radius * 28.0)

    bpy.ops.object.light_add(type="AREA", location=(-radius * 4.0, -radius * 1.2, radius * 0.9))
    key = bpy.context.object
    key.name = f"{name}_FocusKey"
    key.parent = anchor
    key.data.energy = key_energy
    key.data.shape = "RECTANGLE"
    key.data.size = max(4.0, radius * 1.8)
    key.data.size_y = max(4.0, radius * 1.2)
    key.data.color = (1.0, 0.96, 0.88)
    key.constraints.new(type="TRACK_TO").target = target
    key.constraints[0].track_axis = "TRACK_NEGATIVE_Z"
    key.constraints[0].up_axis = "UP_Y"

    bpy.ops.object.light_add(type="AREA", location=(radius * 1.5, radius * 0.8, radius * 0.35))
    fill = bpy.context.object
    fill.name = f"{name}_FocusFill"
    fill.parent = anchor
    fill.data.energy = fill_energy
    fill.data.shape = "RECTANGLE"
    fill.data.size = max(3.0, radius * 1.4)
    fill.data.size_y = max(3.0, radius * 1.0)
    fill.data.color = (0.75, 0.82, 1.0)
    fill.constraints.new(type="TRACK_TO").target = target
    fill.constraints[0].track_axis = "TRACK_NEGATIVE_Z"
    fill.constraints[0].up_axis = "UP_Y"

    return key, fill


def add_orbiting_moon(parent_empty, name, radius, distance, orbit_turns, texture_candidates, color=(0.7, 0.7, 0.7, 1)):
    bpy.ops.object.empty_add(type="PLAIN_AXES", location=(0, 0, 0))
    orbit = bpy.context.object
    orbit.name = f"Orbit_{name}"
    orbit.parent = parent_empty

    bpy.ops.mesh.primitive_uv_sphere_add(segments=48, ring_count=24, radius=radius, location=(distance, 0, 0))
    moon = bpy.context.object
    moon.name = name
    moon.parent = orbit
    bpy.ops.object.shade_smooth()

    mat = make_planet_material(name, texture_candidates, rough=0.88, emission_strength=0.0)
    if not load_texture(*texture_candidates):
        bsdf = mat.node_tree.nodes.get("Principled BSDF")
        if bsdf:
            bsdf.inputs["Base Color"].default_value = color
    moon.data.materials.append(mat)

    orbit.rotation_euler[2] = 0.0
    orbit.keyframe_insert(data_path="rotation_euler", index=2, frame=OPENING_START)
    orbit.rotation_euler[2] = math.radians(360.0 * orbit_turns)
    orbit.keyframe_insert(data_path="rotation_euler", index=2, frame=FINAL_END)
    set_linear_keys(orbit)

    return moon, orbit


def create_ring(parent_obj, name, inner_r, outer_r, tilt_deg, color=(0.8, 0.8, 0.75, 1), alpha=0.35, texture_names=None):
    texture_names = texture_names or []

    major = (inner_r + outer_r) * 0.5
    minor = max((outer_r - inner_r) * 0.5, 0.003)
    bpy.ops.mesh.primitive_torus_add(
        major_radius=major,
        minor_radius=minor,
        major_segments=96,
        minor_segments=24,
        location=(0, 0, 0),
    )
    ring = bpy.context.object
    ring.name = name
    ring.parent = parent_obj
    ring.rotation_euler[0] = math.radians(90.0)
    ring.rotation_euler[1] = math.radians(tilt_deg)

    mat = bpy.data.materials.new(name=f"Mat_{name}")
    mat.use_nodes = True
    mat.blend_method = "BLEND"
    mat.shadow_method = "NONE"
    nodes = mat.node_tree.nodes
    links = mat.node_tree.links
    nodes.clear()

    out = nodes.new("ShaderNodeOutputMaterial")
    bsdf = nodes.new("ShaderNodeBsdfPrincipled")
    bsdf.inputs["Roughness"].default_value = 0.92
    bsdf.inputs["Specular"].default_value = 0.07

    img = load_texture(*texture_names) if texture_names else None
    if img:
        tex = nodes.new("ShaderNodeTexImage")
        tex.image = img
        links.new(tex.outputs["Color"], bsdf.inputs["Base Color"])
        if "Alpha" in tex.outputs:
            links.new(tex.outputs["Alpha"], bsdf.inputs["Alpha"])
        else:
            bsdf.inputs["Alpha"].default_value = alpha
    else:
        bsdf.inputs["Base Color"].default_value = color
        bsdf.inputs["Alpha"].default_value = alpha

    links.new(bsdf.outputs["BSDF"], out.inputs["Surface"])
    ring.data.materials.append(mat)
    return ring


def create_saturn_ring(parent_obj, radius, tilt_deg, texture_names=None):
    texture_names = texture_names or []

    bpy.ops.mesh.primitive_cylinder_add(radius=radius, depth=0.01, location=(0, 0, 0))
    ring = bpy.context.object
    ring.name = "Saturn_Rings"
    ring.parent = parent_obj
    ring.rotation_euler[0] = math.radians(90.0)
    ring.rotation_euler[1] = math.radians(tilt_deg)

    mat = bpy.data.materials.new(name="Mat_Saturn_Rings")
    mat.use_nodes = True
    mat.blend_method = "BLEND"
    mat.shadow_method = "NONE"
    nodes = mat.node_tree.nodes
    links = mat.node_tree.links
    nodes.clear()

    out = nodes.new("ShaderNodeOutputMaterial")
    bsdf = nodes.new("ShaderNodeBsdfPrincipled")
    tex = nodes.new("ShaderNodeTexImage")
    img = load_texture(*texture_names)

    if img:
        tex.image = img
        try:
            tex.image.colorspace_settings.name = "sRGB"
        except Exception:
            pass
        links.new(tex.outputs["Color"], bsdf.inputs["Base Color"])
        if "Alpha" in tex.outputs:
            links.new(tex.outputs["Alpha"], bsdf.inputs["Alpha"])
    else:
        bsdf.inputs["Base Color"].default_value = (0.7, 0.6, 0.5, 1.0)
        bsdf.inputs["Alpha"].default_value = 0.5

    bsdf.inputs["Roughness"].default_value = 0.9
    links.new(bsdf.outputs["BSDF"], out.inputs["Surface"])
    ring.data.materials.append(mat)
    return ring


def create_visible_orbit(radius, name, color=(0.55, 0.7, 1.0, 1.0)):
    bpy.ops.curve.primitive_bezier_circle_add(radius=radius, location=(0, 0, 0))
    orbit = bpy.context.object
    orbit.name = name
    orbit.data.resolution_u = 128
    orbit.data.render_resolution_u = 128
    orbit.data.bevel_depth = 0.02
    orbit.data.bevel_resolution = 4
    orbit.data.fill_mode = "FULL"

    mat = bpy.data.materials.new(name=f"Mat_{name}")
    mat.use_nodes = True
    mat.blend_method = "BLEND"
    mat.shadow_method = "NONE"
    nodes = mat.node_tree.nodes
    links = mat.node_tree.links
    nodes.clear()

    out = nodes.new("ShaderNodeOutputMaterial")
    emission = nodes.new("ShaderNodeEmission")
    emission.inputs["Color"].default_value = color
    emission.inputs["Strength"].default_value = 0.35
    links.new(emission.outputs["Emission"], out.inputs["Surface"])
    orbit.data.materials.append(mat)
    return orbit


